# Service
LOG_LEVEL=INFO
HOST_PORT=8101
# Build profile reported by GET /info (production | development | staging)
BUILD_PROFILE=production

# Runtime profile:
# - production: fail-closed defaults (strict Modbus matching)
# - simulator: tolerant defaults (for non-compliant emulators)
DRYVE_PROFILE=production

# Drive endpoint (use either IGUS_* or DRYVE_* variables)
# IGUS_MOTOR_IP=203.0.113.50          # example: public simulator
IGUS_MOTOR_IP=192.168.1.100            # your drive's local IP
# Real device usually: 502, simulator in this project: 501
IGUS_MOTOR_PORT=502

# Optional explicit driver vars (override IGUS_*)
# DRYVE_HOST=203.0.113.50
# DRYVE_PORT=501
DRYVE_UNIT_ID=0

# Strict defaults for production
DRYVE_ALLOW_TID_MISMATCH=0

# Some Modbus TCP gateways/simulators respond with Unit ID 0x00/0xFF (wildcard)
DRYVE_ALLOW_UNIT_ID_WILDCARD=0

# Debug options (disabled by default)
# DRYVE_TRACE_SDO=1
# DRYVE_VERIFY_MOTION=1

# Poll / event throttle tuning
# Minimum seconds between STATUS events published to the SSE event bus.
# Lower values = more responsive SSE clients; higher values = less CPU/network overhead.
DRYVE_STATUS_EVENT_THROTTLE_S=0.5

# Health score tuning (used by /ready and /metrics)
DRYVE_HEALTH_WEIGHT_DISCONNECTED=50
DRYVE_HEALTH_WEIGHT_STARTUP_ERROR=30
DRYVE_HEALTH_WEIGHT_TELEMETRY_STALE=20
DRYVE_HEALTH_WEIGHT_FAULT_ACTIVE=30
DRYVE_HEALTH_WEIGHT_CALLBACK_ERROR_MAX=20

# Legacy API lifecycle policy
LEGACY_API_DEPRECATION=true
LEGACY_API_PHASE=deprecated
LEGACY_API_SUNSET=Wed, 30 Sep 2026 23:59:59 GMT
LEGACY_API_DOCS_LINK=/docs
LEGACY_API_SUCCESSOR_PATH=/drive
